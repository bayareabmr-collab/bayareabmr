---
import Base from '../layouts/Base.astro';
import ListingCard from '../components/ListingCard.astro';
import FilterBar from '../components/FilterBar.astro';
import Map from '../components/Map.astro';
import '../styles/global.css';

const sampleListings = [
  {
    id: "sunnyvale-villas-001", name: "The Villas at Sunnyvale",
    address: "123 Innovation Way, Sunnyvale, CA", city: "Sunnyvale", status: "open",
    applicationClose: "2026-06-15", ami: [80, 120],
    units: [{ type: "1BR", count: 4, bmrRent: 1890, amiLevel: 80 },{ type: "2BR", count: 2, bmrRent: 2200, amiLevel: 80 },{ type: "3BR", count: 1, bmrRent: 2650, amiLevel: 120 }],
    coordinates: { lat: 37.3688, lng: -122.0363 },
    amenities: ["Pool", "Gym", "EV Charging", "In-Unit W/D"],
    walkScore: 82, bmrRent: 1890, marketRent: 3450, dataSource: "Sunnyvale", lastVerified: "2026-04-01",
  },
  {
    id: "fremont-station-002", name: "Fremont Station Residences",
    address: "456 Warm Springs Blvd, Fremont, CA", city: "Fremont", status: "closing",
    applicationClose: "2026-04-15", ami: [50, 80],
    units: [{ type: "Studio", count: 3, bmrRent: 1200, amiLevel: 50 },{ type: "1BR", count: 5, bmrRent: 1450, amiLevel: 80 },{ type: "2BR", count: 2, bmrRent: 1750, amiLevel: 80 }],
    coordinates: { lat: 37.5168, lng: -121.9465 },
    amenities: ["Gym", "Parking", "Dog Park"],
    walkScore: 71, bmrRent: 1200, marketRent: 2800, dataSource: "Fremont", lastVerified: "2026-04-01",
  },
  {
    id: "mountainview-miro-003", name: "Miro at Mountain View",
    address: "789 El Camino Real, Mountain View, CA", city: "Mountain View", status: "upcoming",
    applicationClose: "2026-08-01", ami: [60, 100],
    units: [{ type: "1BR", count: 6, bmrRent: 2100, amiLevel: 100 },{ type: "2BR", count: 3, bmrRent: 2500, amiLevel: 100 }],
    coordinates: { lat: 37.3861, lng: -122.0839 },
    amenities: ["Rooftop Deck", "Gym", "Package Lockers", "Bike Storage"],
    walkScore: 89, bmrRent: 2100, marketRent: 3800, dataSource: "Mountain View", lastVerified: "2026-04-01",
  },
  {
    id: "sanjose-parkside-004", name: "Parkside Towers",
    address: "200 N 1st St, San Jose, CA", city: "San Jose", status: "open",
    applicationClose: "2026-07-01", ami: [80, 120],
    units: [{ type: "Studio", count: 6, bmrRent: 1450, amiLevel: 80 },{ type: "1BR", count: 3, bmrRent: 1790, amiLevel: 120 }],
    coordinates: { lat: 37.3382, lng: -121.8863 },
    amenities: ["Pool", "Coworking Space", "EV Charging", "Concierge"],
    walkScore: 94, bmrRent: 1450, marketRent: 3200, dataSource: "San Jose", lastVerified: "2026-04-01",
  },
  {
    id: "milpitas-transit-005", name: "Milpitas Transit Village",
    address: "1 S Main St, Milpitas, CA", city: "Milpitas", status: "open",
    applicationClose: "2026-06-30", ami: [50, 80],
    units: [{ type: "1BR", count: 8, bmrRent: 1650, amiLevel: 80 },{ type: "2BR", count: 4, bmrRent: 1950, amiLevel: 80 }],
    coordinates: { lat: 37.4323, lng: -121.8996 },
    amenities: ["Near BART", "Gym", "Playground", "Package Lockers"],
    walkScore: 76, bmrRent: 1650, marketRent: 3100, dataSource: "Milpitas", lastVerified: "2026-04-01",
  },
  {
    id: "santaclara-centro-006", name: "Centro Santa Clara",
    address: "3000 El Camino Real, Santa Clara, CA", city: "Santa Clara", status: "closed",
    applicationClose: "2026-03-15", ami: [60, 80],
    units: [{ type: "1BR", count: 4, bmrRent: 1700, amiLevel: 80 },{ type: "2BR", count: 2, bmrRent: 2050, amiLevel: 80 }],
    coordinates: { lat: 37.3541, lng: -121.9552 },
    amenities: ["Pool", "BBQ Area", "Fitness Center"],
    walkScore: 68, bmrRent: 1700, marketRent: 3000, dataSource: "Santa Clara", lastVerified: "2026-03-15",
  },
];

const cities = ["San Jose", "Fremont", "Milpitas", "Sunnyvale", "Santa Clara", "Mountain View", "Cupertino", "Palo Alto"];
---

<Base title="Bay Area BMR — Affordable Housing Made Findable">
  <section class="hero">
    <div class="container hero__inner">
      <div class="hero__content animate-in">
        <p class="hero__kicker">Free &middot; Open Source &middot; Updated Bimonthly</p>
        <h1 class="hero__title">Find your next home<br/><span class="hero__highlight">at a price you can afford.</span></h1>
        <p class="hero__subtitle">Every Below Market Rate housing listing across 8 Bay Area cities — in one place. Photos, amenities, deadlines, and application links.</p>
      </div>
    </div>
    <div class="hero__gradient" aria-hidden="true"></div>
  </section>

  <section class="listings-section" aria-label="Available BMR listings">
    <div class="container">
      <FilterBar cities={cities} listings={sampleListings} />
      <Map listings={sampleListings} />
      <div class="listings-header">
        <h2><span id="listings-count">{sampleListings.length}</span> listings across 8 cities</h2>
      </div>
      <div class="listings-grid" id="listings-grid">
        {sampleListings.map((listing, i) => (
          <div class="listing-card-wrap" data-name={listing.name} data-address={listing.address} data-city={listing.city} data-status={listing.status} data-units={listing.units.map(u => u.type).join(',')}>
            <ListingCard listing={listing} />
          </div>
        ))}
      </div>
      <div id="empty-state" class="empty-state" style="display:none;">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
        <h3>No listings match your filters</h3>
        <p>Try broadening your search or selecting different filters.</p>
      </div>
    </div>
  </section>

  <section class="value-section">
    <div class="container">
      <div class="value-header animate-in"><h2>Why Bay Area BMR?</h2><p>We built the housing search that should already exist.</p></div>
      <div class="value-grid">
        <div class="value-card animate-in" style="animation-delay:80ms"><div class="value-card__icon">🏘️</div><h3>8 Cities, One Search</h3><p>Stop checking 8 different city websites. Every BMR listing from San Jose to Palo Alto, in one place.</p></div>
        <div class="value-card animate-in" style="animation-delay:160ms"><div class="value-card__icon">📸</div><h3>See What You're Getting</h3><p>Interior photos, amenities, and market-rate comparisons. BMR units are in luxury buildings — we show you that.</p></div>
        <div class="value-card animate-in" style="animation-delay:240ms"><div class="value-card__icon">⏰</div><h3>Never Miss a Deadline</h3><p>Application windows are short. We track every deadline and will notify you when new listings open in your city.</p></div>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { position: relative; padding: var(--space-16) 0 var(--space-12); overflow: hidden; }
  .hero__gradient { position: absolute; inset: 0; background: radial-gradient(ellipse 80% 50% at 50% -20%, var(--color-primary-light) 0%, transparent 60%), radial-gradient(ellipse 40% 40% at 80% 20%, rgba(232, 118, 58, 0.06) 0%, transparent 50%); pointer-events: none; z-index: -1; }
  .hero__inner { display: flex; flex-direction: column; align-items: center; text-align: center; gap: var(--space-6); }
  .hero__kicker { font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); letter-spacing: var(--tracking-wide); text-transform: uppercase; }
  .hero__title { font-size: var(--text-5xl); max-width: 700px; }
  .hero__highlight { background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
  .hero__subtitle { max-width: 560px; font-size: var(--text-lg); color: var(--color-text-secondary); }

  .listings-section { padding: var(--space-8) 0 var(--space-16); }
  .listings-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: var(--space-6); }
  .listings-header h2 { font-size: var(--text-xl); }
  .listings-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(340px, 1fr)); gap: var(--space-6); }

  .empty-state { padding: var(--space-16) 0; text-align: center; display: flex; flex-direction: column; align-items: center; gap: var(--space-4); color: var(--color-text-tertiary); }
  .empty-state h3 { color: var(--color-text-secondary); font-size: var(--text-lg); }

  .value-section { padding: var(--space-20) 0; background: var(--color-surface); border-top: 1px solid var(--color-border-light); }
  .value-header { text-align: center; margin-bottom: var(--space-12); }
  .value-header p { font-size: var(--text-lg); margin-top: var(--space-3); }
  .value-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: var(--space-8); }
  .value-card { text-align: center; padding: var(--space-8) var(--space-6); }
  .value-card__icon { font-size: var(--text-4xl); margin-bottom: var(--space-4); }
  .value-card h3 { margin-bottom: var(--space-3); font-size: var(--text-lg); }
  .value-card p { font-size: var(--text-sm); line-height: var(--leading-relaxed); }

  @media (max-width: 768px) { .hero { padding: var(--space-10) 0 var(--space-8); } .hero__title { font-size: var(--text-3xl); } .listings-grid { grid-template-columns: 1fr; } }
  @media (max-width: 480px) { .hero__title { font-size: var(--text-2xl); } }
</style>

<script>
  // Copy data attributes from wrappers to cards for FilterBar filtering
  document.querySelectorAll('.listing-card-wrap').forEach(wrap => {
    const card = wrap.querySelector('.listing-card');
    if (card) {
      ['name','address','city','status','units'].forEach(attr => {
        const val = wrap.getAttribute(`data-${attr}`);
        if (val) (card as HTMLElement).setAttribute(`data-${attr}`, val);
      });
    }
  });
</script>
