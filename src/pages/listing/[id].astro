---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';

// In production: read from listings.json
// getStaticPaths must be fully self-contained for Astro's build
export function getStaticPaths() {
  const listings = [
    { id: "sunnyvale-villas-001", name: "The Villas at Sunnyvale", address: "123 Innovation Way, Sunnyvale, CA", city: "Sunnyvale", status: "open", applicationClose: "2026-06-15", applicationUrl: "https://example.com/apply", ami: [80, 120], units: [{ type: "1BR", count: 4, bmrRent: 1890, amiLevel: 80 },{ type: "2BR", count: 2, bmrRent: 2200, amiLevel: 80 },{ type: "3BR", count: 1, bmrRent: 2650, amiLevel: 120 }], coordinates: { lat: 37.3688, lng: -122.0363 }, amenities: ["Pool", "Gym", "EV Charging", "In-Unit W/D", "Package Lockers", "Bike Storage", "Rooftop Deck", "BBQ Area"], walkScore: 82, bmrRent: 1890, marketRent: 3450, dataSource: "Sunnyvale", lastVerified: "2026-04-01", propertyManagement: { company: "Prometheus Real Estate", phone: "408-555-0100" }, enrichment: { buildingDescription: "Modern luxury apartment community built in 2022 featuring contemporary finishes, open floor plans, and resort-style amenities. Located minutes from major tech campuses and Caltrain." } },
    { id: "fremont-station-002", name: "Fremont Station Residences", address: "456 Warm Springs Blvd, Fremont, CA", city: "Fremont", status: "closing", applicationClose: "2026-04-15", applicationUrl: "https://example.com/apply2", ami: [50, 80], units: [{ type: "Studio", count: 3, bmrRent: 1200, amiLevel: 50 },{ type: "1BR", count: 5, bmrRent: 1450, amiLevel: 80 },{ type: "2BR", count: 2, bmrRent: 1750, amiLevel: 80 }], coordinates: { lat: 37.5168, lng: -121.9465 }, amenities: ["Gym", "Parking", "Dog Park", "Package Lockers"], walkScore: 71, bmrRent: 1200, marketRent: 2800, dataSource: "Fremont", lastVerified: "2026-04-01", propertyManagement: { company: "Greystar", phone: "510-555-0200" } },
    { id: "mountainview-miro-003", name: "Miro at Mountain View", address: "789 El Camino Real, Mountain View, CA", city: "Mountain View", status: "upcoming", applicationClose: "2026-08-01", applicationUrl: "https://example.com/apply3", ami: [60, 100], units: [{ type: "1BR", count: 6, bmrRent: 2100, amiLevel: 100 },{ type: "2BR", count: 3, bmrRent: 2500, amiLevel: 100 }], coordinates: { lat: 37.3861, lng: -122.0839 }, amenities: ["Rooftop Deck", "Gym", "Package Lockers", "Bike Storage"], walkScore: 89, bmrRent: 2100, marketRent: 3800, dataSource: "Mountain View", lastVerified: "2026-04-01", propertyManagement: { company: "Essex Property Trust", phone: "650-555-0300" } },
    { id: "sanjose-parkside-004", name: "Parkside Towers", address: "200 N 1st St, San Jose, CA", city: "San Jose", status: "open", applicationClose: "2026-07-01", applicationUrl: "https://example.com/apply4", ami: [80, 120], units: [{ type: "Studio", count: 6, bmrRent: 1450, amiLevel: 80 },{ type: "1BR", count: 3, bmrRent: 1790, amiLevel: 120 }], coordinates: { lat: 37.3382, lng: -121.8863 }, amenities: ["Pool", "Coworking Space", "EV Charging", "Concierge"], walkScore: 94, bmrRent: 1450, marketRent: 3200, dataSource: "San Jose", lastVerified: "2026-04-01", propertyManagement: { company: "Charities Housing", phone: "408-555-0400" } },
    { id: "milpitas-transit-005", name: "Milpitas Transit Village", address: "1 S Main St, Milpitas, CA", city: "Milpitas", status: "open", applicationClose: "2026-06-30", applicationUrl: "https://example.com/apply5", ami: [50, 80], units: [{ type: "1BR", count: 8, bmrRent: 1650, amiLevel: 80 },{ type: "2BR", count: 4, bmrRent: 1950, amiLevel: 80 }], coordinates: { lat: 37.4323, lng: -121.8996 }, amenities: ["Near BART", "Gym", "Playground", "Package Lockers"], walkScore: 76, bmrRent: 1650, marketRent: 3100, dataSource: "Milpitas", lastVerified: "2026-04-01", propertyManagement: { company: "MidPen Housing", phone: "408-555-0500" } },
    { id: "santaclara-centro-006", name: "Centro Santa Clara", address: "3000 El Camino Real, Santa Clara, CA", city: "Santa Clara", status: "closed", applicationClose: "2026-03-15", applicationUrl: "https://example.com/apply6", ami: [60, 80], units: [{ type: "1BR", count: 4, bmrRent: 1700, amiLevel: 80 },{ type: "2BR", count: 2, bmrRent: 2050, amiLevel: 80 }], coordinates: { lat: 37.3541, lng: -121.9552 }, amenities: ["Pool", "BBQ Area", "Fitness Center"], walkScore: 68, bmrRent: 1700, marketRent: 3000, dataSource: "Santa Clara", lastVerified: "2026-03-15", propertyManagement: { company: "Eden Housing", phone: "408-555-0600" } },
  ];
  return listings.map(l => ({ params: { id: l.id }, props: { listing: l } }));
}

const { listing } = Astro.props;
const lowestBmr = listing.units?.reduce((min: number, u: any) => u.bmrRent && u.bmrRent < min ? u.bmrRent : min, Infinity) || 0;
const marketRent = listing.marketRent || 0;
const annualSavings = marketRent && lowestBmr ? (marketRent - lowestBmr) * 12 : 0;

const statusMap: Record<string, { label: string; class: string }> = {
  open: { label: '● Open — Accepting Applications', class: 'badge--open' },
  closing: { label: '⏰ Closing Soon', class: 'badge--closing' },
  closed: { label: '○ Closed', class: 'badge--closed' },
  upcoming: { label: '◉ Upcoming', class: 'badge--upcoming' },
};
const status = statusMap[listing.status] || statusMap.open;
---

<Base title={`${listing.name} — Bay Area BMR`} description={`BMR housing at ${listing.name}, ${listing.city}. Units from $${lowestBmr}/mo.`}>
  <div class="detail-page">
    <div class="container">
      <!-- Back link -->
      <a href="/" class="back-link animate-in">← Back to listings</a>

      <!-- Header -->
      <div class="detail-header animate-in">
        <div class="detail-header__top">
          <span class={`badge ${status.class}`}>{status.label}</span>
          <span class="detail-header__city">{listing.city}</span>
        </div>
        <h1>{listing.name}</h1>
        <p class="detail-header__address">{listing.address}</p>
      </div>

      <div class="detail-grid">
        <!-- Main content -->
        <div class="detail-main">
          <!-- Photo placeholder -->
          <div class="detail-photo animate-in" style="animation-delay:80ms">
            <div class="detail-photo__placeholder">
              <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
              <span>Photos will appear here once the enrichment pipeline connects</span>
            </div>
          </div>

          <!-- Description -->
          {listing.enrichment?.buildingDescription && (
            <div class="detail-section animate-in" style="animation-delay:120ms">
              <h2>About This Property</h2>
              <p>{listing.enrichment.buildingDescription}</p>
            </div>
          )}

          <!-- Units & Pricing -->
          <div class="detail-section animate-in" style="animation-delay:160ms">
            <h2>Available Units & Pricing</h2>
            <div class="units-table-wrap">
              <table class="units-table">
                <thead>
                  <tr>
                    <th>Unit Type</th>
                    <th>Available</th>
                    <th>BMR Rent</th>
                    <th>AMI Level</th>
                    {marketRent > 0 && <th>Market Rate</th>}
                    {marketRent > 0 && <th>You Save</th>}
                  </tr>
                </thead>
                <tbody>
                  {listing.units.map((u: any) => (
                    <tr>
                      <td><strong>{u.type}</strong></td>
                      <td>{u.count} units</td>
                      <td class="price-cell">${u.bmrRent?.toLocaleString()}/mo</td>
                      <td>{u.amiLevel}% AMI</td>
                      {marketRent > 0 && <td class="market-cell">${marketRent.toLocaleString()}/mo</td>}
                      {marketRent > 0 && u.bmrRent && <td class="savings-cell">${(marketRent - u.bmrRent).toLocaleString()}/mo</td>}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            {annualSavings > 0 && (
              <div class="annual-savings">
                <span class="annual-savings__label">Total annual savings vs. market rate</span>
                <span class="annual-savings__amount">${annualSavings.toLocaleString()}/year</span>
              </div>
            )}
          </div>

          <!-- Amenities -->
          {listing.amenities?.length > 0 && (
            <div class="detail-section animate-in" style="animation-delay:200ms">
              <h2>Amenities</h2>
              <div class="amenities-grid">
                {listing.amenities.map((a: string) => <span class="amenity amenity--lg">{a}</span>)}
              </div>
            </div>
          )}

          <!-- Scores -->
          {listing.walkScore && (
            <div class="detail-section animate-in" style="animation-delay:240ms">
              <h2>Neighborhood</h2>
              <div class="scores-row">
                <div class="score-block">
                  <span class="score-block__value">{listing.walkScore}</span>
                  <span class="score-block__label">Walk Score</span>
                </div>
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="detail-sidebar animate-in" style="animation-delay:100ms">
          <div class="sidebar-card">
            <div class="sidebar-card__price">
              <span class="sidebar-card__label">BMR rent from</span>
              <span class="sidebar-card__amount">${lowestBmr.toLocaleString()}<span class="sidebar-card__period">/mo</span></span>
            </div>

            {marketRent > 0 && (
              <div class="savings savings--lg">
                <span>Save ${(marketRent - lowestBmr).toLocaleString()}/mo</span>
              </div>
            )}

            <div class="sidebar-card__detail">
              <span class="sidebar-card__detail-label">Application Deadline</span>
              <span class="sidebar-card__detail-value">{listing.applicationClose}</span>
            </div>

            <div class="sidebar-card__detail">
              <span class="sidebar-card__detail-label">AMI Levels</span>
              <span class="sidebar-card__detail-value">{listing.ami.join('%, ')}% AMI</span>
            </div>

            {listing.propertyManagement && (
              <div class="sidebar-card__detail">
                <span class="sidebar-card__detail-label">Property Management</span>
                <span class="sidebar-card__detail-value">{listing.propertyManagement.company}</span>
                {listing.propertyManagement.phone && <span class="sidebar-card__detail-sub">{listing.propertyManagement.phone}</span>}
              </div>
            )}

            <div class="sidebar-card__detail">
              <span class="sidebar-card__detail-label">Last Verified</span>
              <span class="sidebar-card__detail-value">{listing.lastVerified}</span>
            </div>

            <div class="sidebar-card__detail">
              <span class="sidebar-card__detail-label">Data Source</span>
              <span class="sidebar-card__detail-value">City of {listing.dataSource} (CPRA)</span>
            </div>

            {listing.applicationUrl && listing.status !== 'closed' ? (
              <a href={listing.applicationUrl} target="_blank" rel="noopener" class="btn btn--accent btn--lg sidebar-card__cta">
                Apply Now →
              </a>
            ) : listing.status === 'closed' ? (
              <button class="btn btn--secondary btn--lg sidebar-card__cta" disabled>
                Applications Closed
              </button>
            ) : (
              <button class="btn btn--primary btn--lg sidebar-card__cta" disabled>
                Opening Soon
              </button>
            )}
          </div>
        </aside>
      </div>
    </div>
  </div>
</Base>

<style>
  .detail-page { padding: var(--space-8) 0 var(--space-20); }

  .back-link { display: inline-block; font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); margin-bottom: var(--space-6); }
  .back-link:hover { color: var(--color-primary-dark); }

  .detail-header { margin-bottom: var(--space-8); }
  .detail-header__top { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-3); }
  .detail-header__city { font-size: var(--text-sm); color: var(--color-text-tertiary); font-weight: 500; }
  .detail-header h1 { font-size: var(--text-4xl); margin-bottom: var(--space-2); }
  .detail-header__address { font-size: var(--text-lg); color: var(--color-text-secondary); }

  .detail-grid { display: grid; grid-template-columns: 1fr 360px; gap: var(--space-8); align-items: start; }

  .detail-main { display: flex; flex-direction: column; gap: var(--space-8); }

  .detail-photo { border-radius: var(--radius-lg); overflow: hidden; }
  .detail-photo__placeholder { aspect-ratio: 16/9; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-3); background: var(--color-surface-sunken); color: var(--color-text-tertiary); font-size: var(--text-sm); text-align: center; padding: var(--space-8); }

  .detail-section h2 { font-size: var(--text-xl); margin-bottom: var(--space-4); }
  .detail-section p { color: var(--color-text-secondary); line-height: var(--leading-relaxed); }

  .units-table-wrap { overflow-x: auto; border-radius: var(--radius-md); border: 1px solid var(--color-border-light); }
  .units-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .units-table th, .units-table td { padding: var(--space-3) var(--space-4); text-align: left; border-bottom: 1px solid var(--color-border-light); }
  .units-table th { background: var(--color-surface-sunken); font-weight: 600; font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--color-text-secondary); }
  .units-table tbody tr:hover { background: var(--color-primary-light); }
  .price-cell { font-weight: 700; color: var(--color-primary); }
  .market-cell { color: var(--color-text-tertiary); text-decoration: line-through; }
  .savings-cell { font-weight: 700; color: var(--color-success); }

  .annual-savings { display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) var(--space-5); background: linear-gradient(135deg, var(--color-success-light), #d4f5e5); border-radius: var(--radius-md); margin-top: var(--space-4); }
  .annual-savings__label { font-size: var(--text-sm); font-weight: 500; color: var(--color-text-secondary); }
  .annual-savings__amount { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; color: var(--color-success); }

  .amenities-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .amenity--lg { padding: var(--space-2) var(--space-4); font-size: var(--text-sm); }

  .scores-row { display: flex; gap: var(--space-6); }
  .score-block { display: flex; flex-direction: column; align-items: center; padding: var(--space-4) var(--space-6); background: var(--color-surface-sunken); border-radius: var(--radius-md); }
  .score-block__value { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 700; color: var(--color-primary); }
  .score-block__label { font-size: var(--text-xs); font-weight: 600; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: var(--tracking-wide); margin-top: var(--space-1); }

  /* Sidebar */
  .detail-sidebar { position: sticky; top: 80px; }
  .sidebar-card { background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-md); display: flex; flex-direction: column; gap: var(--space-5); }
  .sidebar-card__label { font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; }
  .sidebar-card__amount { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 700; }
  .sidebar-card__period { font-size: var(--text-base); font-weight: 400; color: var(--color-text-tertiary); }
  .savings--lg { padding: var(--space-3) var(--space-4); font-size: var(--text-base); }

  .sidebar-card__detail { display: flex; flex-direction: column; gap: var(--space-1); padding-top: var(--space-3); border-top: 1px solid var(--color-border-light); }
  .sidebar-card__detail-label { font-size: var(--text-xs); font-weight: 600; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
  .sidebar-card__detail-value { font-size: var(--text-sm); font-weight: 600; color: var(--color-text); }
  .sidebar-card__detail-sub { font-size: var(--text-sm); color: var(--color-text-secondary); }

  .sidebar-card__cta { width: 100%; text-align: center; text-decoration: none; margin-top: var(--space-2); }
  .sidebar-card__cta:disabled { opacity: 0.5; cursor: not-allowed; }

  @media (max-width: 900px) {
    .detail-grid { grid-template-columns: 1fr; }
    .detail-sidebar { position: static; order: -1; }
    .detail-header h1 { font-size: var(--text-3xl); }
  }
</style>
