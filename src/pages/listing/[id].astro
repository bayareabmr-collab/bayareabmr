---
import Base from '../../layouts/Base.astro';
import '../../styles/global.css';
import { getListings } from '../../lib/listings.js';

export function getStaticPaths() {
  const listings = getListings();
  return listings.map(l => ({ params: { id: l.id }, props: { listing: l } }));
}

const { listing } = Astro.props;
const lowestBmr = listing.units?.reduce((min: number, u: any) => u.bmrRent && u.bmrRent < min ? u.bmrRent : min, Infinity) || 0;
const marketRent = listing.enrichment?.marketRent
  ? Math.max(...Object.values(listing.enrichment.marketRent) as number[])
  : listing.marketRent || 0;
const annualSavings = marketRent && lowestBmr && lowestBmr < Infinity ? (marketRent - lowestBmr) * 12 : 0;
const photos = listing.enrichment?.photos || [];
const hasPhoto = photos.length > 0;
const amenities = listing.enrichment?.amenities || listing.amenities || [];
const walkScore = listing.enrichment?.walkScore || listing.walkScore;

const statusI18nMap: Record<string, { label: string; cls: string; i18nKey: string }> = {
  open: { label: '● Open — Accepting Applications', cls: 'badge--open', i18nKey: 'listing.openAccepting' },
  closing: { label: '⏰ Closing Soon', cls: 'badge--closing', i18nKey: 'listing.closingSoonBadge' },
  closed: { label: '○ Closed', cls: 'badge--closed', i18nKey: 'listing.closedBadge' },
  upcoming: { label: '◉ Upcoming', cls: 'badge--upcoming', i18nKey: 'listing.upcomingBadge' },
};
const status = statusI18nMap[listing.status] || statusI18nMap.open;
const pm = listing['propertyManagement.company'] || listing.propertyManagement?.company;
const pmPhone = listing['propertyManagement.phone'] || listing.propertyManagement?.phone;
---

<Base title={`${listing.name} — Bay Area BMR`} description={`BMR housing at ${listing.name}, ${listing.city}. ${listing.affordableUnits || ''} affordable units.`}>
  <div class="detail-page">
    <div class="container">
      <a href="/" class="back-link animate-in" data-i18n="detail.backToListings">← Back to listings</a>

      <div class="detail-header animate-in">
        <div class="detail-header__top">
          <span class={`badge ${status.cls}`} data-i18n={status.i18nKey}>{status.label}</span>
          <span class="detail-header__city">{listing.city}</span>
        </div>
        <h1>{listing.name}</h1>
        <p class="detail-header__address">{listing.address}</p>
      </div>

      <div class="detail-grid">
        <div class="detail-main">
          <!-- Photo -->
          <div class="detail-photo animate-in" style="animation-delay:80ms">
            {hasPhoto ? (
              <img src={photos[0].url} alt={`Photo of ${listing.name}`} class="detail-photo__img" loading="lazy" />
            ) : (
              <div class="detail-photo__placeholder">
                <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/></svg>
                <span data-i18n="listing.photosComingSoon">Photos will appear here once the enrichment pipeline connects</span>
              </div>
            )}
          </div>

          <!-- Description -->
          {listing.enrichment?.buildingDescription && (
            <div class="detail-section animate-in" style="animation-delay:120ms">
              <h2 data-i18n="detail.aboutProperty">About This Property</h2>
              <p>{listing.enrichment.buildingDescription}</p>
            </div>
          )}

          <!-- Project info for Oakland portfolio listings -->
          {listing.projectType && (
            <div class="detail-section animate-in" style="animation-delay:120ms">
              <h2 data-i18n="detail.aboutProperty">About This Property</h2>
              <p>{listing.notes}</p>
              {listing.totalUnits && <p>Total units in building: {listing.totalUnits}. Affordable units: {listing.affordableUnits}.</p>}
            </div>
          )}

          <!-- Units & Pricing -->
          <div class="detail-section animate-in" style="animation-delay:160ms">
            <h2 data-i18n="detail.unitsAndPricing">Available Units & Pricing</h2>
            <div class="units-table-wrap">
              <table class="units-table">
                <thead>
                  <tr>
                    <th data-i18n="detail.unitType">Unit Type</th>
                    <th data-i18n="detail.available">Available</th>
                    {listing.units?.some((u: any) => u.bmrRent) && <th data-i18n="detail.bmrRent">BMR Rent</th>}
                    <th data-i18n="detail.amiLevel">AMI Level</th>
                    {marketRent > 0 && <th data-i18n="detail.marketRate">Market Rate</th>}
                    {marketRent > 0 && <th data-i18n="detail.youSave">You Save</th>}
                  </tr>
                </thead>
                <tbody>
                  {listing.units?.map((u: any) => (
                    <tr>
                      <td><strong>{u.type}</strong></td>
                      <td>{u.count} <span data-i18n="detail.units">units</span></td>
                      {u.bmrRent && <td class="price-cell">${u.bmrRent?.toLocaleString()}/mo</td>}
                      <td>{u.amiLevel}% AMI</td>
                      {marketRent > 0 && <td class="market-cell">${marketRent.toLocaleString()}/mo</td>}
                      {marketRent > 0 && u.bmrRent && <td class="savings-cell">${(marketRent - u.bmrRent).toLocaleString()}/mo</td>}
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            {annualSavings > 0 && (
              <div class="annual-savings">
                <span class="annual-savings__label" data-i18n="detail.annualSavings">Total annual savings vs. market rate</span>
                <span class="annual-savings__amount">${annualSavings.toLocaleString()}<span data-i18n="detail.perYear">/year</span></span>
              </div>
            )}
          </div>

          <!-- Amenities -->
          {amenities.length > 0 && (
            <div class="detail-section animate-in" style="animation-delay:200ms">
              <h2 data-i18n="detail.amenities">Amenities</h2>
              <div class="amenities-grid">
                {amenities.map((a: string) => <span class="amenity amenity--lg">{a}</span>)}
              </div>
            </div>
          )}

          <!-- Walk Score -->
          {walkScore && (
            <div class="detail-section animate-in" style="animation-delay:240ms">
              <h2 data-i18n="detail.neighborhood">Neighborhood</h2>
              <div class="scores-row">
                <div class="score-block">
                  <span class="score-block__value">{walkScore}</span>
                  <span class="score-block__label" data-i18n="detail.walkScore">Walk Score</span>
                </div>
              </div>
            </div>
          )}
        </div>

        <!-- Sidebar -->
        <aside class="detail-sidebar">
          <div class="sidebar-card">
            {lowestBmr > 0 && lowestBmr < Infinity && (
              <div>
                <span class="sidebar-card__label" data-i18n="detail.bmrRentFrom">BMR rent from</span>
                <span class="sidebar-card__amount">${lowestBmr.toLocaleString()}<span class="sidebar-card__period">/mo</span></span>
              </div>
            )}

            {marketRent > 0 && lowestBmr > 0 && lowestBmr < Infinity && (
              <div class="savings savings--lg">Save ${(marketRent - lowestBmr).toLocaleString()}/mo vs. market rate</div>
            )}

            {listing.applicationClose && (
              <div class="sidebar-card__detail">
                <span class="sidebar-card__detail-label" data-i18n="detail.applicationDeadline">Application Deadline</span>
                <span class="sidebar-card__detail-value">{listing.applicationClose}</span>
              </div>
            )}

            {listing.ami?.length > 0 && (
              <div class="sidebar-card__detail">
                <span class="sidebar-card__detail-label" data-i18n="detail.amiLevels">AMI Levels</span>
                <span class="sidebar-card__detail-value">{listing.ami.join('%, ')}% AMI</span>
              </div>
            )}

            {pm && (
              <div class="sidebar-card__detail">
                <span class="sidebar-card__detail-label" data-i18n="detail.propertyManagement">Property Management</span>
                <span class="sidebar-card__detail-value">{pm}</span>
                {pmPhone && <span class="sidebar-card__detail-sub">{pmPhone}</span>}
              </div>
            )}

            <div class="sidebar-card__detail">
              <span class="sidebar-card__detail-label" data-i18n="detail.lastVerified">Last Verified</span>
              <span class="sidebar-card__detail-value">{listing.lastVerified}</span>
            </div>

            <div class="sidebar-card__detail">
              <span class="sidebar-card__detail-label" data-i18n="detail.dataSource">Data Source</span>
              <span class="sidebar-card__detail-value">{listing.dataSource} (CPRA)</span>
            </div>

            {listing.applicationUrl && listing.status !== 'closed' ? (
              <a href={listing.applicationUrl} target="_blank" rel="noopener noreferrer" class="btn btn--accent btn--lg sidebar-card__cta" data-i18n="detail.applyNow">
                Apply Now →
              </a>
            ) : listing.status === 'closed' ? (
              <button class="btn btn--secondary btn--lg sidebar-card__cta" disabled data-i18n="detail.applicationsClosed">
                Applications Closed
              </button>
            ) : (
              <button class="btn btn--primary btn--lg sidebar-card__cta" disabled data-i18n="detail.openingSoon">
                Opening Soon
              </button>
            )}
          </div>
        </aside>
      </div>
    </div>
  </div>
</Base>

<style>
  .detail-page { padding: var(--space-8) 0 var(--space-20); }

  .back-link { display: inline-block; font-size: var(--text-sm); font-weight: 600; color: var(--color-primary); margin-bottom: var(--space-6); }
  .back-link:hover { color: var(--color-primary-dark); }

  .detail-header { margin-bottom: var(--space-8); }
  .detail-header__top { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-3); }
  .detail-header__city { font-size: var(--text-sm); color: var(--color-text-tertiary); font-weight: 500; }
  .detail-header h1 { font-size: var(--text-4xl); margin-bottom: var(--space-2); }
  .detail-header__address { font-size: var(--text-lg); color: var(--color-text-secondary); }

  .detail-grid { display: grid; grid-template-columns: 1fr 360px; gap: var(--space-8); align-items: start; }
  .detail-main { display: flex; flex-direction: column; gap: var(--space-8); }

  .detail-photo { border-radius: var(--radius-lg); overflow: hidden; }
  .detail-photo__img { width: 100%; aspect-ratio: 16/9; object-fit: cover; }
  .detail-photo__placeholder { aspect-ratio: 16/9; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: var(--space-3); background: var(--color-surface-sunken); color: var(--color-text-tertiary); font-size: var(--text-sm); text-align: center; padding: var(--space-8); }

  .detail-section h2 { font-size: var(--text-xl); margin-bottom: var(--space-4); }
  .detail-section p { color: var(--color-text-secondary); line-height: var(--leading-relaxed); }

  .units-table-wrap { overflow-x: auto; border-radius: var(--radius-md); border: 1px solid var(--color-border-light); }
  .units-table { width: 100%; border-collapse: collapse; font-size: var(--text-sm); }
  .units-table th, .units-table td { padding: var(--space-3) var(--space-4); text-align: left; border-bottom: 1px solid var(--color-border-light); }
  .units-table th { background: var(--color-surface-sunken); font-weight: 600; font-size: var(--text-xs); text-transform: uppercase; letter-spacing: var(--tracking-wide); color: var(--color-text-secondary); }
  .units-table tbody tr:hover { background: var(--color-primary-light); }
  .price-cell { font-weight: 700; color: var(--color-primary); }
  .market-cell { color: var(--color-text-tertiary); text-decoration: line-through; }
  .savings-cell { font-weight: 700; color: var(--color-success); }

  .annual-savings { display: flex; align-items: center; justify-content: space-between; padding: var(--space-4) var(--space-5); background: linear-gradient(135deg, var(--color-success-light), #d4f5e5); border-radius: var(--radius-md); margin-top: var(--space-4); }
  .annual-savings__label { font-size: var(--text-sm); font-weight: 500; color: var(--color-text-secondary); }
  .annual-savings__amount { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 700; color: var(--color-success); }

  .amenities-grid { display: flex; flex-wrap: wrap; gap: var(--space-2); }
  .amenity--lg { padding: var(--space-2) var(--space-4); font-size: var(--text-sm); }

  .scores-row { display: flex; gap: var(--space-6); }
  .score-block { display: flex; flex-direction: column; align-items: center; padding: var(--space-4) var(--space-6); background: var(--color-surface-sunken); border-radius: var(--radius-md); }
  .score-block__value { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 700; color: var(--color-primary); }
  .score-block__label { font-size: var(--text-xs); font-weight: 600; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: var(--tracking-wide); margin-top: var(--space-1); }

  .detail-sidebar { position: sticky; top: 80px; }
  .sidebar-card { background: var(--color-surface); border: 1px solid var(--color-border-light); border-radius: var(--radius-lg); padding: var(--space-6); box-shadow: var(--shadow-md); display: flex; flex-direction: column; gap: var(--space-5); }
  .sidebar-card__label { font-size: var(--text-xs); color: var(--color-text-tertiary); display: block; }
  .sidebar-card__amount { font-family: var(--font-display); font-size: var(--text-3xl); font-weight: 700; }
  .sidebar-card__period { font-size: var(--text-base); font-weight: 400; color: var(--color-text-tertiary); }
  .savings--lg { padding: var(--space-3) var(--space-4); font-size: var(--text-base); }

  .sidebar-card__detail { display: flex; flex-direction: column; gap: var(--space-1); padding-top: var(--space-3); border-top: 1px solid var(--color-border-light); }
  .sidebar-card__detail-label { font-size: var(--text-xs); font-weight: 600; color: var(--color-text-tertiary); text-transform: uppercase; letter-spacing: var(--tracking-wide); }
  .sidebar-card__detail-value { font-size: var(--text-sm); font-weight: 600; color: var(--color-text); }
  .sidebar-card__detail-sub { font-size: var(--text-sm); color: var(--color-text-secondary); }

  .sidebar-card__cta { width: 100%; text-align: center; text-decoration: none; margin-top: var(--space-2); }
  .sidebar-card__cta:disabled { opacity: 0.5; cursor: not-allowed; }

  @media (max-width: 900px) {
    .detail-grid { grid-template-columns: 1fr; }
    .detail-sidebar { position: static; order: -1; }
    .detail-header h1 { font-size: var(--text-3xl); }
  }

  @media (max-width: 480px) {
    .detail-page { padding: var(--space-4) 0 var(--space-12); }
    .detail-header h1 { font-size: var(--text-2xl); }
    .detail-header__address { font-size: var(--text-sm); }
    .units-table { font-size: var(--text-xs); }
    .units-table th, .units-table td { padding: var(--space-2); }
    .annual-savings { flex-direction: column; text-align: center; gap: var(--space-2); }
    .scores-row { flex-wrap: wrap; }
  }
</style>
