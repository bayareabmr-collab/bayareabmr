---
const langs = [
  { code: 'en', native: 'English' },
  { code: 'es', native: 'Español' },
  { code: 'zh', native: '中文' },
  { code: 'vi', native: 'Tiếng Việt' },
  { code: 'tl', native: 'Tagalog' },
  { code: 'hi', native: 'हिन्दी' },
  { code: 'ko', native: '한국어' },
  { code: 'ja', native: '日本語' },
  { code: 'fa', native: 'فارسی' },
  { code: 'pa', native: 'ਪੰਜਾਬੀ' },
];
---

<div class="lang-picker">
  <label for="lang-select" class="sr-only">Language</label>
  <div class="lang-picker__wrapper">
    <span class="lang-picker__globe" aria-hidden="true">🌐</span>
    <select id="lang-select" class="lang-picker__select">
      {langs.map(l => (
        <option value={l.code}>{l.native}</option>
      ))}
    </select>
    <span class="lang-picker__arrow" aria-hidden="true">▾</span>
  </div>
</div>

<style>
  .lang-picker {
    position: relative;
  }
  .lang-picker__wrapper {
    display: flex;
    align-items: center;
    position: relative;
    background: var(--color-surface-sunken);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }
  .lang-picker__globe {
    position: absolute;
    left: 8px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 14px;
    line-height: 1;
    pointer-events: none;
    z-index: 1;
  }
  .lang-picker__arrow {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 10px;
    color: var(--color-text-tertiary);
    pointer-events: none;
    z-index: 1;
  }
  .lang-picker__select {
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    background: transparent;
    border: none;
    outline: none;
    padding: 6px 24px 6px 28px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    color: var(--color-text-secondary);
    cursor: pointer;
    min-width: 0;
    width: auto;
    line-height: 1.4;
  }
  .lang-picker__select:focus {
    outline: none;
  }
  .lang-picker__wrapper:focus-within {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 2px var(--color-primary-glow);
  }

  @media (max-width: 768px) {
    .lang-picker__select {
      font-size: 11px;
      padding: 5px 20px 5px 24px;
    }
    .lang-picker__globe {
      font-size: 12px;
      left: 6px;
    }
    .lang-picker__arrow {
      right: 6px;
    }
  }
</style>

<script>
  const select = document.getElementById('lang-select') as HTMLSelectElement;
  if (select) {
    const stored = localStorage.getItem('bmr-lang');
    const browser = navigator.language?.slice(0, 2);
    const supported = ['en','es','zh','vi','tl','hi','ko','ja','fa','pa'];
    const current = stored && supported.includes(stored) ? stored : (browser && supported.includes(browser) ? browser : 'en');
    select.value = current;

    select.addEventListener('change', () => {
      localStorage.setItem('bmr-lang', select.value);
      document.documentElement.lang = select.value;
      document.documentElement.dir = select.value === 'fa' ? 'rtl' : 'ltr';
      window.location.reload();
    });
  }
</script>
