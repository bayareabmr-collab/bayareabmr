---
interface Props {
  listings: any[];
}

const { listings } = Astro.props;
const listingsWithCoords = listings.filter(l => l.coordinates?.lat && l.coordinates?.lng);
---

<div class="map-container" id="map-container">
  <button class="map-toggle btn btn--secondary" id="map-toggle">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <polygon points="1 6 1 22 8 18 16 22 23 18 23 2 16 6 8 2 1 6"/>
      <line x1="8" y1="2" x2="8" y2="18"/><line x1="16" y1="6" x2="16" y2="22"/>
    </svg>
    <span id="map-toggle-text">Show Map</span>
  </button>

  <div class="map-wrapper" id="map-wrapper" style="display:none;">
    <div id="leaflet-map" class="leaflet-map"></div>
  </div>
</div>

<style>
  .map-container {
    margin-bottom: var(--space-6);
  }
  .map-toggle {
    margin-bottom: var(--space-4);
  }
  .map-wrapper {
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-md);
    animation: fadeIn var(--duration-normal) var(--ease-out);
  }
  .leaflet-map {
    height: 400px;
    width: 100%;
    background: var(--color-surface-sunken);
  }

  @media (max-width: 768px) {
    .leaflet-map { height: 300px; }
  }
</style>

<script define:vars={{ listingsWithCoords }}>
  let mapLoaded = false;
  let map = null;

  const toggle = document.getElementById('map-toggle');
  const wrapper = document.getElementById('map-wrapper');
  const toggleText = document.getElementById('map-toggle-text');

  toggle?.addEventListener('click', () => {
    const isHidden = wrapper.style.display === 'none';
    wrapper.style.display = isHidden ? 'block' : 'none';
    toggleText.textContent = isHidden ? 'Hide Map' : 'Show Map';

    if (isHidden && !mapLoaded) {
      loadMap();
    }
  });

  function loadMap() {
    // Load Leaflet CSS
    const css = document.createElement('link');
    css.rel = 'stylesheet';
    css.href = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.css';
    document.head.appendChild(css);

    // Load Leaflet JS
    const script = document.createElement('script');
    script.src = 'https://unpkg.com/leaflet@1.9.4/dist/leaflet.js';
    script.onload = () => {
      initMap();
    };
    document.head.appendChild(script);
  }

  function initMap() {
    const L = window.L;
    // Center on South Bay
    map = L.map('leaflet-map').setView([37.38, -121.95], 11);

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
      maxZoom: 18,
    }).addTo(map);

    // Custom marker color
    function createIcon(status) {
      const colors = {
        open: '#22a867',
        closing: '#d9920b',
        closed: '#999',
        upcoming: '#1a7a6d',
      };
      const color = colors[status] || colors.open;
      return L.divIcon({
        className: 'custom-marker',
        html: `<div style="background:${color};width:14px;height:14px;border-radius:50%;border:2.5px solid white;box-shadow:0 2px 6px rgba(0,0,0,0.3);"></div>`,
        iconSize: [14, 14],
        iconAnchor: [7, 7],
        popupAnchor: [0, -10],
      });
    }

    // Add markers
    const bounds = [];
    for (const listing of listingsWithCoords) {
      const lat = listing.coordinates.lat;
      const lng = listing.coordinates.lng;
      bounds.push([lat, lng]);

      const lowestRent = listing.units?.reduce((min, u) =>
        u.bmrRent && u.bmrRent < min ? u.bmrRent : min, Infinity) || 0;

      const popup = `
        <div style="font-family:DM Sans,sans-serif;min-width:200px;">
          <strong style="font-size:14px;">${listing.name}</strong><br/>
          <span style="color:#4a6360;font-size:12px;">${listing.address}</span><br/>
          ${lowestRent > 0 ? `<span style="font-size:15px;font-weight:700;color:#1c2b2a;">$${lowestRent.toLocaleString()}/mo</span><br/>` : ''}
          ${listing.ami?.length ? `<span style="font-size:11px;color:#7a9491;">${Math.min(...listing.ami)}–${Math.max(...listing.ami)}% AMI</span><br/>` : ''}
          <a href="/listing/${listing.id || ''}" style="color:#1a7a6d;font-size:12px;font-weight:600;text-decoration:none;">View Details →</a>
        </div>
      `;

      L.marker([lat, lng], { icon: createIcon(listing.status) })
        .addTo(map)
        .bindPopup(popup);
    }

    // Fit bounds if we have markers
    if (bounds.length > 1) {
      map.fitBounds(bounds, { padding: [40, 40] });
    }

    mapLoaded = true;

    // Fix tile rendering after container becomes visible
    setTimeout(() => map.invalidateSize(), 100);
  }
</script>
